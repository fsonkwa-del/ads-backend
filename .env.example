# ── Base de données MySQL ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=ads_db

# TLS pour MySQL managé (TiDB Cloud, Aiven, Cloud SQL). En local : laisser DB_SSL vide.
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false   # mettre false pour une démo si vous ne fournissez pas le CA

# ── Serveur ───────────────────────────────────────────
PORT=3001

# ── CORS ──────────────────────────────────────────────
# Origine autorisée du frontend (ex. https://mon-projet.web.app). Vide = toutes (démo).
# CORS_ORIGIN=

# Authentification
JWT_SECRET=remplacer-par-une-chaine-aleatoire-longue
JWT_EXPIRES=12h
